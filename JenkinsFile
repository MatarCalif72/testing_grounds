pipeline {
    agent any


    environment {
        FRONTEND_IMAGE = "inventory-frontend-app:v${env.BUILD_NUMBER}"
        BACKEND_IMAGE = "inventory-project-backend:v${env.BUILD_NUMBER}"
    }

    stages {
        stage('Build images') {
            steps {
                    echo "Building Frontend..."
                    bat "docker build -t ${FRONTEND_IMAGE} ./frontend"
                    echo "Building Backend..."
                    bat "docker build -t ${BACKEND_IMAGE} ./backend"
                }
            }
        
        stage('Load to minikube') {
            steps {
                echo 'Loading frontend image'
                bat "minikube image load ${FRONTEND_IMAGE}"
                echo "Loading backend image"
                bat "minikube image load ${BACKEND_IMAGE}"
            }
        }
        stage('Deploy to kubernetes') {
            steps {
                echo 'Updating frontend deployment'
                bat "kubectl set image deployment/inventory-frontend-app frontend-app=${FRONTEND_IMAGE}"
                echo "Updating Backend Deployment..."
                bat "kubectl set image deployment/inventory-backend java-app=${BACKEND_IMAGE}"
                echo "Waiting for rollout..."
                bat "kubectl rollout status deployment/inventory-frontend-app"
                bat "kubectl rollout status deployment/inventory-backend"
            }
        }
    }

//change

    post {
        success {
            echo "Deployment successful! :D"
            bat "kubectl get pods -l app=inventory-frontend-app"
            bat "kubectl get pods -l app=inventory-backend"
        }
        failure {
            echo "Deployment failed. D:<"
            bat "kubectl get pods -l app=inventory-frontend-app"
            bat "kubectl get pods -l app=inventory-backend"
        }
  
    }
}
